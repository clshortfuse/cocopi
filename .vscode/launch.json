{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Cocopi Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--enable-proposed-api=cocopi"
      ],
      "outFiles": [],
      "preLaunchTask": "npm: check"
    },
    {
      "name": "Cocopi: Build",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run package:vsix",
      "cwd": "${workspaceFolder}"
    }
  ]
}
