{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2023",
    "lib": ["ES2023"],
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["data/vscode-dts/**/*.d.ts", "extension.js", "data/**/*.js", "lib/**/*.js", "scripts/**/*.js", "test/**/*.js"],
  "exclude": ["node_modules", "types", "out", "dist"]
}
