# Copy to .env for local live testing. Never commit real tokens.

# ChatGPT/Codex login tokens. These are written by npm run setup:codex-login.
COCOPI_AUTH_MODE=chatgpt_browser
CODEX_CHATGPT_ACCESS_TOKEN=
CODEX_CHATGPT_REFRESH_TOKEN=
CODEX_CHATGPT_ID_TOKEN=
CODEX_CHATGPT_ACCOUNT_ID=
CODEX_CHATGPT_PLAN_TYPE=

# Codex ChatGPT auth issuer.
CODEX_AUTH_ISSUER=https://auth.openai.com

# Initial direct Codex API target. ChatGPT auth uses this backend by default.
CODEX_API_BASE_URL=https://chatgpt.com/backend-api/codex
CODEX_MODEL=gpt-5.5
CODEX_CLIENT_VERSION=0.144.0

# Live tests use the model configured in CODEX_MODEL when local credentials are present.
